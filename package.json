{
  "name": "ai-task-flow",
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "tauri": "node scripts/run-tauri.mjs",
    "setup": "node scripts/setup-tasks.mjs",
    "postinstall": "node scripts/setup-tasks.mjs",
    "dev:vite": "vite",
    "build:vite": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "dev": "node scripts/run-tauri.mjs dev",
    "build": "node scripts/run-tauri.mjs build",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{js,ts,html,css}\" \"*.{ts,js,json}\"",
    "format:check": "prettier --check \"src/**/*.{js,ts,html,css}\"",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "wdio run tests/e2e/wdio.conf.cjs",
    "build:bindings": "node scripts/run-cargo.mjs test export_bindings --manifest-path src-tauri/Cargo.toml",
    "rust:check": "node scripts/run-cargo.mjs check --manifest-path src-tauri/Cargo.toml",
    "rust:test": "node scripts/run-cargo.mjs test --manifest-path src-tauri/Cargo.toml"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@types/mocha": "^10",
    "@types/node": "^22",
    "@vitest/coverage-v8": "^3.2.4",
    "@wdio/cli": "^9",
    "@wdio/globals": "^9",
    "@wdio/local-runner": "^9",
    "@wdio/mocha-framework": "^9",
    "@wdio/spec-reporter": "^9",
    "eslint": "^10.3.0",
    "expect-webdriverio": "^5",
    "happy-dom": "^20.9.0",
    "prettier": "^3.8.3",
    "tsx": "^4",
    "typescript": "^5",
    "typescript-eslint": "^8.59.1",
    "vite": "^7.3.2",
    "vitest": "^3",
    "webdriverio": "^9"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@tauri-apps/plugin-shell": "^2"
  }
}
